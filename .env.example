# Backend SMTP / Email Settings (Hostinger)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_EMAIL="your-email@yourdomain.com"
SMTP_PASSWORD="your-email-password"

# Backend IMAP Settings (Hostinger)
IMAP_HOST="imap.hostinger.com"
IMAP_PORT=993

# Database URL (PostgreSQL)
# Format: postgresql://user:password@hostname:port/dbname
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hostinger_cold_email"

# API & Tracking Configuration
TRACKING_BASE_URL="http://localhost:8000"
BACKEND_API_SECRET="websual_dev_secret_key"

# Groq AI Classification (Optional)
GROQ_API_KEY=""

# Next.js Frontend Configuration
NEXT_PUBLIC_API_URL="http://127.0.0.1:8000/api"
